# Source backend active
# Valeurs : in_memory (Module 2), bigquery (Module 3+), mock_legacy (Module 4+)
SOURCE_KIND=in_memory

# BigQuery — paramètres d'environnement uniquement
GCP_PROJECT=anything-here
BQ_DATASET=bigquery-public-data.usda_nass_agriculture

# Mock Legacy
MOCK_FIXTURES_PATH=./data/mock_legacy_fixtures.json

# Logs
LOG_LEVEL=INFO
